# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Option 1: URL complète de la base de données (recommandé)
DATABASE_URL=postgresql://postgres:root@localhost:5432/acathecpa

# Option 2: Configuration par composants (alternative à DATABASE_URL)
# Si vous préférez définir chaque composant séparément, décommentez les lignes ci-dessous
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=root
# POSTGRES_SERVER=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=acathecpa

# =============================================================================
# JWT/AUTHENTICATION CONFIGURATION
# =============================================================================
SECRET_KEY=your_very_secret_key_for_jwt_generation_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
FRONTEND_URL=http://localhost:5173

# =============================================================================
# EMAIL/MAIL CONFIGURATION
# =============================================================================
# OBLIGATOIRE: Remplacez par vos vraies valeurs email
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-mot-de-passe-app
MAIL_FROM=votre-email@gmail.com
MAIL_FROM_NAME=ACATHECPA Application
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
USE_CREDENTIALS=True
VALIDATE_CERTS=True
MAIL_ENABLED=True

# =============================================================================
# ALTERNATIVE EMAIL CONFIGURATIONS
# =============================================================================
# Pour Outlook/Hotmail:
# MAIL_SERVER=smtp-mail.outlook.com
# MAIL_PORT=587

# Pour Yahoo:
# MAIL_SERVER=smtp.mail.yahoo.com
# MAIL_PORT=587

# Pour un serveur SMTP personnalisé:
# MAIL_SERVER=your-smtp-server.com
# MAIL_PORT=587

# =============================================================================
# DEVELOPMENT/PRODUCTION NOTES
# =============================================================================
# En production, assurez-vous de :
# 1. Changer SECRET_KEY par une clé vraiment secrète et unique
# 2. Utiliser des mots de passe forts pour la base de données
# 3. Configurer correctement les paramètres email avec vos vraies credentials
# 4. Ajuster FRONTEND_URL selon votre domaine de production

# Jitsi / JaaS Settings
# JITSI_APP_ID=vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# JITSI_DOMAIN=8x8.vc
# JITSI_JWT=your_jaas_jwt